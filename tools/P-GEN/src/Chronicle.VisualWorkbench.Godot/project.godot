; PROTOTYPE — E5.1 authoring workbench, never a runtime dependency
config_version=5

[application]

config/name="P-GEN Visual Workbench"
run/main_scene="res://Workbench.tscn"

[display]

window/size/viewport_width=1440
window/size/viewport_height=900
window/size/window_width_override=1440
window/size/window_height_override=900
window/stretch/mode="canvas_items"

[dotnet]

project/assembly_name="Chronicle.VisualWorkbench.Godot"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/default_filters/use_nearest_mipmap_filter=false
